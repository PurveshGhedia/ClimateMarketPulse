# ── Data — NEVER commit raw or processed data ──────────────────────
data/
*.db
*.sqlite
*.sqlite3
*.csv
*.tsv
*.parquet
*.json
*.jsonl

# ── Logs ────────────────────────────────────────────────────────────
logs/
*.log

# ── Python ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ─────────────────────────────────────────────
venv/
env/
.venv/
.env/
ENV/

# ── Jupyter Notebooks ────────────────────────────────────────────────
.ipynb_checkpoints/
# Keep .ipynb files themselves — commit notebooks
# but not their checkpoint folders

# ── Models & large binaries ──────────────────────────────────────────
models/
*.bin
*.pt
*.pth
*.ckpt
*.h5
*.pkl
*.pickle

# ── Environment & secrets ────────────────────────────────────────────
.env
.env.local
*.env
secrets.py
config_local.py

# ── OS clutter ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Playwright ───────────────────────────────────────────────────────
playwright-report/
test-results/
scraper/et_debug.html
scraper/et_debug.png
scraper/pib_filter_debug.py
scraper/test_loop.py
